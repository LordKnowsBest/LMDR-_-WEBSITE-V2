export async function rosGetRecruiterConversations(recruiterId) { return await getRecruiterConversations(recruiterId); }
export async function rosGetUnreadCount(recruiterId) { return await getUnreadCount(recruiterId); }

// --- Feature Adoption ---
export async function rosLogFeatureInteraction(feature, action, meta) { return await logFeatureInteraction(feature, action, meta); }

// --- Driver Search ---
export async function rosFindMatchingDrivers(criteria) { return await findMatchingDrivers(criteria); }
export async function rosGetDriverProfile(id) { return await getDriverProfile(id); }
export async function rosInitiateAsyncDriverSearch(criteria) { return await initiateAsyncDriverSearch(criteria); }
export async function rosCheckAsyncSearchStatus(jobId) { return await checkAsyncSearchStatus(jobId); }

// --- Driver Outreach ---
export async function rosSaveToRecruiterPipeline(driverId, carrierDot, notes) { return await saveToRecruiterPipeline(driverId, carrierDot, notes); }
