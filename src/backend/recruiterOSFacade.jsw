// ============================================================================
// RE-EXPORTS — thin async wrappers (one per function the page code calls)
// ============================================================================

// --- Core Recruiter ---
export async function rosGetOrCreateRecruiterProfile() { return await getOrCreateRecruiterProfile(); }
export async function rosAddCarrier(dot) { return await addCarrier(dot); }
export async function rosRemoveCarrier(dot) { return await removeCarrier(dot); }
export async function rosGetRecruiterCarriers() { return await getRecruiterCarriers(); }
export async function rosValidateCarrierDOT(dot) { return await validateCarrierDOT(dot); }
export async function rosGetPipelineCandidates(dot, filters) { return await getPipelineCandidates(dot, filters); }
export async function rosUpdateCandidateStatus(id, status, notes) { return await updateCandidateStatus(id, status, notes); }
export async function rosGetPipelineStats(dot) { return await getPipelineStats(dot); }
export async function rosGetCandidateDetails(id) { return await getCandidateDetails(id); }
export async function rosAddRecruiterNotes(id, notes) { return await addRecruiterNotes(id, notes); }
export async function rosUpdateRecruiterProfile(data) { return await updateRecruiterProfile(data); }

// --- Interview ---
export async function rosRequestAvailability(driverId, carrierId, recruiterSlots) { return await requestAvailability(driverId, carrierId, recruiterSlots); }
export async function rosConfirmTimeSlot(interviewId, slotIndex) { return await confirmTimeSlot(interviewId, slotIndex); }
export async function rosGetInterviewState(interviewId) { return await getInterviewState(interviewId); }

// --- Messaging ---
export async function rosSendMessage(conversationId, text) { return await sendMessage(conversationId, text); }
